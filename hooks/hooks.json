{
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "\"$HOME/.clawbar/bin/clawbar\" hook SessionStart", "async": true } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "\"$HOME/.clawbar/bin/clawbar\" hook UserPromptSubmit", "async": true } ] }
    ],
    "PreToolUse": [
      { "matcher": "*", "hooks": [ { "type": "command", "command": "\"$HOME/.clawbar/bin/clawbar\" hook PreToolUse", "async": true } ] }
    ],
    "PostToolUse": [
      { "matcher": "*", "hooks": [ { "type": "command", "command": "\"$HOME/.clawbar/bin/clawbar\" hook PostToolUse", "async": true } ] }
    ],
    "Notification": [
      { "matcher": "*", "hooks": [ { "type": "command", "command": "\"$HOME/.clawbar/bin/clawbar\" hook Notification", "async": true } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "\"$HOME/.clawbar/bin/clawbar\" hook Stop", "async": true } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "\"$HOME/.clawbar/bin/clawbar\" hook SessionEnd", "async": true } ] }
    ]
  }
}
